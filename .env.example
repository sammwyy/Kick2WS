# Public base URL of this service. Used to build the OAuth redirect and webhook
# URLs. In production this must be an HTTPS URL reachable by Kick.
PUBLIC_URL=http://localhost:3000

# HTTP port to listen on.
PORT=3000

# Kick OAuth app credentials. Create an app in the Kick developer settings and
# set its Redirect URI to <PUBLIC_URL>/oauth/callback and its Webhook URL to
# <PUBLIC_URL>/webhook.
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# Default OAuth scopes to request. Callers may narrow these at login time.
KICK_DEFAULT_SCOPES=user:read channel:read events:subscribe

# Kick webhook events to subscribe to after OAuth, as comma-separated name:version.
KICK_EVENTS=channel.followed:1,channel.subscription.new:1,channel.subscription.renewal:1,channel.subscription.gifts:1,chat.message.sent:1,livestream.status.updated:1

# Secret used to sign session JWTs. Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
APP_SECRET=change-me-please

# SQLite database file path.
DB_PATH=./data/kick2ws.db

# Set to 1 to skip webhook signature verification. Local testing only.
INSECURE_SKIP_WEBHOOK_VERIFY=0
